# OPTIONAL AUTH FALLBACK (not required if using auth_login tool)
NEWTON_SESSION_COOKIE=auth-token=...
# you can also set only the raw token value; server normalizes it to auth-token=<value>
# OR
NEWTON_AUTH_TOKEN=your_bearer_token

# OPTIONAL
NEWTON_BASE_URL=https://my.newtonschool.co
NEWTON_COURSE_HASH=your_default_course_hash
NEWTON_USERNAME=your_newton_username
NEWTON_SUBMIT_POLL_ATTEMPTS=8
NEWTON_SUBMIT_POLL_INTERVAL_MS=1200
NEWTON_AUTH_STORE_PATH=/path/to/auth.json
NEWTON_PERSIST_AUTH=true
NEWTON_HTTP_ALLOW_PERSIST=false
NEWTON_SESSION_TTL_SECONDS=21600
REDIS_URL=redis://localhost:6379
REDIS_SESSION_PREFIX=newton-submit-mcp:auth:
MCP_RATE_LIMIT_ENABLED=true
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_RATE_LIMIT_MAX=120
